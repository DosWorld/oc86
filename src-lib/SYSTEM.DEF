MODULE SYSTEM
CONST SYSTEM_FCarry     1
CONST SYSTEM_FParity    4
CONST SYSTEM_FAuxiliary 16
CONST SYSTEM_FZero      64
CONST SYSTEM_FSign      128
CONST SYSTEM_FOverflow  2048
TYPE SYSTEM_Registers RECORD 18
  FIELD AX    INTEGER 0  2
  FIELD BX    INTEGER 2  2
  FIELD CX    INTEGER 4  2
  FIELD DX    INTEGER 6  2
  FIELD SI    INTEGER 8  2
  FIELD DI    INTEGER 10 2
  FIELD DS    INTEGER 12 2
  FIELD ES    INTEGER 14 2
  FIELD Flags INTEGER 16 2
END
PROC SYSTEM_INIT FAR VOID
END
PROC SYSTEM_DONE FAR VOID
END
PROC SYSTEM_CallFar FAR VOID
  PARAM ProcPtr POINTER VOID
  PARAM VAR Regs SYSTEM_Registers
END
PROC SYSTEM_Intr FAR VOID
  PARAM IntNo BYTE
  PARAM VAR Regs SYSTEM_Registers
END
PROC SYSTEM_mAlloc FAR POINTER VOID
  PARAM sizeInBytes INTEGER
END
PROC SYSTEM_mFree FAR VOID
  PARAM p POINTER VOID
END
PROC _S32MUL FAR LONGINT
  PARAM a LONGINT
  PARAM b LONGINT
END
PROC _S32DIV FAR LONGINT
  PARAM a LONGINT
  PARAM b LONGINT
END
PROC _S32MOD FAR LONGINT
  PARAM a LONGINT
  PARAM b LONGINT
END
